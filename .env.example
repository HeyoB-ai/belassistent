# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+31xxxxxxxxx

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (https://elevenlabs.io) — voor de spraak (<Play> i.p.v. Twilio Polly)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Stem-ID's uit je ElevenLabs-account (kies Nederlandse/multilingual stemmen).
# Zonder deze vallen we terug op ElevenLabs-standaardstemmen.
ELEVENLABS_VOICE_AI=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_AGENT=ErXwobaYiN019PkySvjV

# Gesprek-tuning (optioneel; defaults tussen haakjes)
# SPEECH_TIMEOUT: de speechTimeout van de <Gather>. "auto" vangt hele menu-opties op;
#   zet op "1" of "1.5" voor een snappere beurt-overgang bij mensgesprekken.
SPEECH_TIMEOUT=auto
# MAX_DTMF: max aantal toetskeuzes zonder medewerker voordat de AI "0" probeert en anders ophangt. (5)
MAX_DTMF=5
# MAX_HOLD_MINUTES: absolute wachttijd-bovengrens (minuten). Een normale wachtrij mag lang
# duren; dit grijpt alleen in tegen een nummer dat nooit een medewerker geeft. (10)
MAX_HOLD_MINUTES=10

# URL — Netlify vult deze automatisch met de deploy-URL (bv. https://jouw-site.netlify.app).
# Alleen lokaal handmatig zetten als je webhooks test (bv. via een tunnel/ngrok-URL).
URL=http://localhost:8888
